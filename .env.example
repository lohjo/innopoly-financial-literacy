# Vite app
# Optional: browser → tutor WebSocket. Prefer the Vite proxy (default below).
VITE_TUTOR_WS_URL=ws://localhost:5173/tutor-ws
# Optional shared secret; must match TUTOR_ACCESS_TOKEN when set.
# VITE_TUTOR_ACCESS_TOKEN=

# Optional generative phrasing helpers (default off — fake-transport tested offline)
# VITE_MANAGED_AGENTS=false

# --- TS Live Tutor server (started by `pnpm run dev`) ---
TUTOR_PORT=8080
TUTOR_ALLOWED_ORIGINS=http://localhost:5173
# TUTOR_ACCESS_TOKEN=

# Gemini Live (optional). Without these, /healthz is "degraded" and the app
# still teaches via authored hints + deterministic Check.
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Set to 1 to run Vite only (skip tutor child process).
# TUTOR_DISABLED=0
