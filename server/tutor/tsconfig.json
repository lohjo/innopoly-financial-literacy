{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["node"],
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": false
  },
  "include": ["./**/*.ts"]
}
